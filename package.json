{
  "name": "@carlosrodrigo/pi-config",
  "version": "0.1.0",
  "description": "Personal pi extensions and themes — bordered editor, file opener, catppuccin theme",
  "keywords": ["pi-package"],
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test:auto-prompt": "node --test extensions/auto-prompt/auto-prompt.test.ts",
    "test:web-tools": "node --test extensions/web-tools/web-tools.test.ts",
    "test:workflow-modes": "node --test extensions/workflow-modes/workflow-modes.test.ts",
    "test:lazygit": "node --test extensions/lazygit/lazygit.test.ts",
    "test:bordered-editor": "node --test extensions/bordered-editor/bordered-editor.test.ts",
    "test:dumb-zone": "node --test extensions/dumb-zone/dumb-zone.test.ts",
    "test:verify": "node --test extensions/verify/verify.test.ts",
    "test:direct": "node --test extensions/auto-prompt/auto-prompt.test.ts extensions/web-tools/web-tools.test.ts extensions/workflow-modes/workflow-modes.test.ts extensions/lazygit/lazygit.test.ts extensions/document-reviewer/review-flow.test.ts extensions/bordered-editor/bordered-editor.test.ts extensions/dumb-zone/dumb-zone.test.ts extensions/verify/verify.test.ts",
    "test:document-reviewer": "node scripts/test-document-reviewer.mjs",
    "test": "npm run test:direct && npm run test:document-reviewer"
  },
  "pi": {
    "extensions": ["./extensions"]
  },
  "dependencies": {
    "diff": "^7.0.0",
    "turndown": "^7.2.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
