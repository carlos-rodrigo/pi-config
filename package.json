{
  "name": "@carlosrodrigo/pi-config",
  "version": "0.1.0",
  "description": "Personal pi extensions and themes — bordered editor, file opener, catppuccin theme",
  "keywords": ["pi-package"],
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test:auto-prompt": "node --test tests/extensions/auto-prompt.test.ts",
    "test:workflow-modes": "node --test tests/extensions/workflow-modes.test.ts",
    "test:direct": "node --test tests/extensions/auto-prompt.test.ts tests/extensions/workflow-modes.test.ts extensions/document-reviewer/review-flow.test.ts",
    "test:document-reviewer": "node scripts/test-document-reviewer.mjs",
    "test": "npm run test:direct && npm run test:document-reviewer"
  },
  "pi": {
    "extensions": ["./extensions"]
  },
  "dependencies": {
    "diff": "^7.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
